{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "echo 'Skipping pnpm install'",
  "buildCommand": "echo 'Skipping pnpm build'",
  "functions": {
    "api/webhook.py": {
      "runtime": "python3.12",
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    {
      "source": "/telegram/webhook",
      "destination": "/api/webhook.py"
    },
    {
      "source": "/health",
      "destination": "/api/webhook.py"
    }
  ]
}

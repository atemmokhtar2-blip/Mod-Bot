# ════════════════════════════════════════════════════════════════════════
#  Environment variables — copy to .env for local dev, set on Vercel for prod
#  NEVER commit your actual .env file to source control.
# ════════════════════════════════════════════════════════════════════════

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Required. Obtain from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Recommended. A random secret string (min 32 chars) passed to Telegram's
# setWebhook call as secret_token. Vercel webhook handler verifies this on
# every incoming request so only Telegram can POST to your endpoint.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=

# ── Database ─────────────────────────────────────────────────────────────────
# Required. External PostgreSQL connection string (Replit's internal DB is
# not reachable from Vercel). Recommended providers:
#   • Neon (neon.tech)    — generous free tier, serverless-optimised
#   • Supabase            — full Postgres + REST/realtime extras
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# The app automatically strips ?sslmode=... and forces SSL=false for asyncpg.
DATABASE_URL=

# ── API Server (Node.js) ──────────────────────────────────────────────────────
NODE_ENV=production
# PORT is injected automatically by Vercel — do NOT override it here.

# ── Optional ──────────────────────────────────────────────────────────────────
# Logging verbosity for the Python bot webhook. Default: INFO.
# Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
